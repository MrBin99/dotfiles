{
  /* --- Bash --- */
  "terminal.integrated.shell.windows": "ubuntu.exe",

  /* --- General editor --- */
  "editor.fontSize": 14,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontLigatures": true,
  "editor.detectIndentation": false,
  "editor.renderFinalNewline": true,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.rulers": [80],
  "editor.wordWrap": "off",
  "editor.tabCompletion": "on",
  "editor.insertSpaces": true,
  "editor.suggestOnTriggerCharacters": true,
  "editor.semanticHighlighting.enabled": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": true,
    "source.organizeImports": true
  },
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },

  /* --- Files --- */
  "files.insertFinalNewline": true,
  "files.enableTrash": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.eol": "\n",
  "files.associations": {
    "**/requirements/**,*}.{txt,in}": "pip-requirements",
    "*.vhtml": "vue-html",
    "*.dhtml": "django-html",
    "*.html": "html"
  },

  /* --- Interface --- */
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "breadcrumbs.enabled": true,
  "breadcrumbs.symbolSortOrder": "position",
  "breadcrumbs.filePath": "off",
  "workbench.settings.useSplitJSON": false,
  "workbench.settings.editor": "json",
  "explorer.openEditors.visible": 0,
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "editor.minimap.showSlider": "always",

  /* --- Debugger --- */
  "debug.openExplorerOnEnd": true,
  "debug.toolBarLocation": "docked",
  "debug.console.closeOnEnd": true,
  "debug.inlineValues": true,
  "debug.openDebug": "openOnSessionStart",

  /* --- Icons --- */
  "material-icon-theme.files.associations": {
    "*.vhtml": "vue",
    "*.dhtml": "django",
    "*.glsl": "prisma",
    "*.vert": "prisma",
    "*.frag": "julia",
    "*.html": "html"
  },

  /* ----------------------- Extensions ------------------------ */
  "extensions.ignoreRecommendations": false,

  /* --- Vetur --- */
  "vetur.format.defaultFormatter.css": "prettier",
  "vetur.format.defaultFormatter.scss": "prettier",
  "vetur.format.defaultFormatter.js": "prettier",
  "vetur.format.defaultFormatter.html": "prettyhtml",
  "vetur.format.defaultFormatter.ts": "prettier",
  "vetur.validation.script": true,
  "vetur.validation.style": true,
  "vetur.validation.template": true,
  "vetur.format.scriptInitialIndent": true,
  "vetur.format.styleInitialIndent": true,
  "vetur.format.defaultFormatterOptions": {
    "prettier": {
      "semi": true,
      "singleQuote": true
    }
  },

  /* --- Prettier --- */
  "prettier.vueIndentScriptAndStyle": true,
  "prettier.singleQuote": true,
  "prettier.jsxSingleQuote": true,
  "prettier.semi": true,
  "prettier.trailingComma": "es5",
  "prettier.endOfLine": "lf",
  "prettier.htmlWhitespaceSensitivity": "ignore",
  "prettier.useEditorConfig": false,

  /* --- Emmet --- */
  "emmet.includeLanguages": {
    "blade": "html",
    "django-html": "html",
    "postcss": "css"
  },

  /* --- Watch SASS --- */
  "liveSassCompile.settings.autoprefix": ["> 1%", "last 2 versions"],
  "liveSassCompile.settings.formats": [
    {
      "format": "compressed",
      "extensionName": ".css",
      "savePath": null
    }
  ],

  /* --- Autostring --- */
  "autoDocstring.docstringFormat": "docblockr",
  "autoDocstring.guessTypes": true,
  "autoDocstring.startOnNewLine": true,

  /* --- PHP Docblocker --- */
  "php-docblocker.qualifyClassNames": true,
  "php-docblocker.useShortNames": false,
  "php-docblocker.author": {
    "name": "MrBin99"
  },

  /* --- Todo+ --- */
  "todo.timekeeping.created.enabled": true,
  "todo.timekeeping.created.format": "DD/MM/YY HH:mm",
  "todo.timekeeping.started.format": "DD/MM/YY HH:mm",
  "todo.timekeeping.finished.format": "DD/MM/YY HH:mm",
  "todo.embedded.regex": "(?:<!-- *)?(?:#|// @|//|/\\*+|<!--|--|\\* @|\\{!|\\{\\{!--|\\{\\{!) *(TODO|FIXME|FIX|BUG|UGLY|HACK|NOTE|IDEA|REVIEW|DEBUG|OPTIMIZE)(?:\\s*\\([^)]+\\))?:(?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|\\{!|\\{\\{!--|\\{\\{!))|((?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|\\{!|\\{\\{!--|\\{\\{!))|(?: +[^@\\n]+)?))",

  /* --- Git --- */
  "scm.defaultViewMode": "tree",
  "git.autorefresh": true,
  "gitlens.currentLine.enabled": false,
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.codeLens.enabled": false,
  "gitlens.views.repositories.location": "scm",
  "gitlens.views.fileHistory.location": "scm",
  "gitlens.views.search.location": "scm",
  "gitlens.views.lineHistory.location": "scm",
  "gitlens.views.compare.location": "scm",

  /* --- Comment Divider */
  "comment-divider.languagesMap": {
    "cmake": ["#", "#"]
  },

  /* --------------------- Languages ------------------------- */

  /* --- HTML --- */
  "html.format.enable": true,
  "html.validate.styles": true,
  "html.validate.scripts": true,
  "html.autoClosingTags": true,
  "html.format.extraLiners": "",
  "html.format.wrapLineLength": 0,
  "html.format.indentInnerHtml": true,
  "html.format.endWithNewline": true,

  /* --- JavaScript --- */
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- TypeScript --- */
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- TypeScript React --- */
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- HTML --- */
  "[html]": {
    "editor.tabSize": 2,
    "editor.rulers": [],
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[django-html]": {
    "editor.tabSize": 2,
    "editor.rulers": [],
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    }
  },

  /* --- C++ --- */
  "cmake.configureOnEdit": true,
  "cmake.configureOnOpen": true,
  "cmake.clearOutputBeforeBuild": true,
  "cmake.revealLog": "focus",
  "cmake.parseBuildDiagnostics": true,
  "cmake.loggingLevel": "info",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "${buildType}"
  },
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.clang_format_style": "{ BasedOnStyle: Microsoft, AllowShortFunctionsOnASingleLine: None, IndentWidth: 2, ContinuationIndentWidth: 2, ConstructorInitializerIndentWidth: 2, IndentCaseLabels: true, TabWidth: 2, UseTab: Never, ColumnLimit: 80, PointerAlignment: Left, AllowShortIfStatementsOnASingleLine: false, MaxEmptyLinesToKeep: 1, NamespaceIndentation: All, IndentPPDirectives: BeforeHash, AlwaysBreakTemplateDeclarations: Yes, BreakConstructorInitializers: BeforeColon, AllowAllConstructorInitializersOnNextLine: true }",

  /* --- CSS --- */
  "[css]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- SCSS --- */
  "[scss]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- JSON --- */
  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- JSONC --- */
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  /* --- Vue --- */
  "[vue]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "octref.vetur"
  },

  /* --- Python --- */
  "python.showStartPage": false,
  "python.languageServer": "Pylance",
  "[python]": {
    "editor.tabSize": 4
  },

  /* --- PHP --- */
  "[php]": {
    "editor.tabSize": 4
  }
}
